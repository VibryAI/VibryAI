# ═══════════════════════════════════════════════
# Vibry AI Core — 环境配置模板
# 复制为 .env 并修改
# ═══════════════════════════════════════════════

# ---- 上游 LLM API（兼容 OpenAI 格式）----
# Chat 模型（对话、摘要等）
CHAT_BASE_URL=
CHAT_API_KEY=
CHAT_MODEL=
# Embedding 模型（向量化、语义检索）
# 留空默认本地 bge-small-zh (零配置可用)
# 云端切换: 后台 → Embedding → Provider 选 Cloud
EMBEDDING_BASE_URL=   # 本地留空=local://, 云端填 https://...
EMBEDDING_API_KEY=    # 本地留空
EMBEDDING_MODEL=      # 本地: BAAI/bge-small-zh-v1.5, 云端: doubao-embedding-text-240715
# 以下为兼容旧配置 — 若上面的 CHAT_*/EMBEDDING_* 不填则自动回退
UPSTREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
UPSTREAM_API_KEY=your-api-key-here
UPSTREAM_MODEL=doubao-seed-2-1-turbo-260628
UPSTREAM_EMBEDDING_MODEL=doubao-embedding-text-240715

# ---- ASR 语音识别 ----
# cloud = 豆包极速版（推荐）, cloud_standard = 豆包标准版（说话人分离）
# funasr_server = 本地 FunASR 独立服务（8008 端口，需单独启动）
ASR_MODE=cloud
CLOUD_ASR_MODEL=doubao-seed-2-0-mini-260428
# HuggingFace 镜像（国内加速）
HF_ENDPOINT=https://hf-mirror.com

# ---- 会议纪要 ----
# 留空则使用 UPSTREAM_MODEL
SUMMARY_MODEL=
# 用户画像
USER_NAME=用户
USER_ROLE=创始人
USER_CONTEXT=关注现金流、项目进度、团队协作。偏好简洁直接的沟通风格，重视数据驱动决策。
USER_DEFAULT_TAGS=会议纪要,行动项,决策记录

# ---- 服务 ----
SERVER_PORT=9999
SERVER_HOST=0.0.0.0
LOG_LEVEL=INFO
# CORS 允许的源（逗号分隔，* = 允许所有；生产环境建议指定具体域名）
CORS_ORIGINS=*

# ---- Admin 管理后台 ----
ADMIN_PASSWORD=vibry2024

# ---- 邮件服务 ----
# provider: agentmail (推荐) | smtp
EMAIL_PROVIDER=agentmail

# AgentMail 配置（EMAIL_PROVIDER=agentmail）
# 注册: https://agentmail.to
AGENTMAIL_API_KEY=am_...
AGENTMAIL_FROM_EMAIL=vibryai@agentmail.to

# SMTP 配置（EMAIL_PROVIDER=smtp）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your-email@qq.com
# SMTP_PASS=your-auth-code

# Embedding 向量维度（必须与 UPSTREAM_EMBEDDING_MODEL 输出一致）
# doubao-embedding-text-240715 = 2048; 切换模型时需同步修改
EMBEDDING_DIMS=2048

# Semantic retrieval uses the configured cloud provider when an API key is set.
# Otherwise it requires the configured local FastEmbed model and never silently hashes.
COGNITION_SEMANTIC_MODE=auto
